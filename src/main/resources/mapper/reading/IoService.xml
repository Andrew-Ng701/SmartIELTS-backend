<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.reading.mapper.ReadingTestMapper">

    <resultMap id="ReadingTestResultMap" type="com.andrew.smartielts.reading.domain.pojo.ReadingTest">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="total_score" property="totalScore"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, total_score, created_time
    </sql>

    <insert id="insert"
            parameterType="com.andrew.smartielts.reading.domain.pojo.ReadingTest"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO reading_test (title, total_score, created_time)
        VALUES (#{title}, #{totalScore}, #{createdTime})
    </insert>

    <select id="findById" resultMap="ReadingTestResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM reading_test
        WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="ReadingTestResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM reading_test
        ORDER BY id DESC
    </select>

    <update id="update"
            parameterType="com.andrew.smartielts.reading.domain.pojo.ReadingTest">
        UPDATE reading_test
        SET title = #{title},
        total_score = #{totalScore}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM reading_test
        WHERE id = #{id}
    </delete>

</mapper>
