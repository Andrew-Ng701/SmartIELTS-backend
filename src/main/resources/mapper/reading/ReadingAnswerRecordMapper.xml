<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.reading.mapper.ReadingAnswerRecordMapper">

    <resultMap id="ReadingAnswerRecordResultMap" type="com.andrew.smartielts.reading.domain.pojo.ReadingAnswerRecord">
        <id column="id" property="id"/>
        <result column="record_id" property="recordId"/>
        <result column="question_id" property="questionId"/>
        <result column="user_answer" property="userAnswer"/>
        <result column="is_correct" property="isCorrect"/>
        <result column="score" property="score"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, record_id, question_id, user_answer, is_correct, score
    </sql>

    <insert id="insert"
            parameterType="com.andrew.smartielts.reading.domain.pojo.ReadingAnswerRecord"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO reading_answer_record
        (record_id, question_id, user_answer, is_correct, score)
        VALUES
        (#{recordId}, #{questionId}, #{userAnswer}, #{isCorrect}, #{score})
    </insert>

    <select id="findByRecordId" resultMap="ReadingAnswerRecordResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM reading_answer_record
        WHERE record_id = #{recordId}
        ORDER BY id ASC
    </select>

    <delete id="deleteByRecordId">
        DELETE FROM reading_answer_record
        WHERE record_id = #{recordId}
    </delete>

</mapper>
