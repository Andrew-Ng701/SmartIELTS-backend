<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.reading.mapper.ReadingPassageMapper">

    <resultMap id="ReadingPassageResultMap" type="com.andrew.smartielts.reading.domain.pojo.ReadingPassage">
        <id column="id" property="id"/>
        <result column="test_id" property="testId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, test_id, title, content
    </sql>

    <insert id="insert"
            parameterType="com.andrew.smartielts.reading.domain.pojo.ReadingPassage"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO reading_passage (test_id, title, content)
        VALUES (#{testId}, #{title}, #{content})
    </insert>

    <select id="findById" resultMap="ReadingPassageResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM reading_passage
        WHERE id = #{id}
    </select>

    <select id="findByTestId" resultMap="ReadingPassageResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM reading_passage
        WHERE test_id = #{testId}
        ORDER BY id ASC
    </select>

    <update id="update"
            parameterType="com.andrew.smartielts.reading.domain.pojo.ReadingPassage">
        UPDATE reading_passage
        SET title = #{title},
        content = #{content}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM reading_passage
        WHERE id = #{id}
    </delete>

    <delete id="deleteByTestId">
        DELETE FROM reading_passage
        WHERE test_id = #{testId}
    </delete>

</mapper>
