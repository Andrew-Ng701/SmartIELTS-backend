<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.writing.mapper.WritingRecordAttachmentMapper">

    <resultMap id="WritingRecordAttachmentResultMap" type="com.andrew.smartielts.writing.domain.pojo.WritingRecordAttachment">
        <id column="id" property="id"/>
        <result column="record_id" property="recordId"/>
        <result column="file_type" property="fileType"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_key" property="fileKey"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_time" property="createdTime"/>
        <result column="ocr_text" property="ocrText"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, record_id, file_type, file_url, file_key, sort_order, created_time, ocr_text
    </sql>

    <insert id="insert"
            parameterType="com.andrew.smartielts.writing.domain.pojo.WritingRecordAttachment"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO writing_record_attachment
        (
        record_id,
        file_type,
        file_url,
        file_key,
        sort_order,
        created_time,
        ocr_text
        )
        VALUES
        (
        #{recordId},
        #{fileType},
        #{fileUrl},
        #{fileKey},
        #{sortOrder},
        #{createdTime},
        #{ocrText}
        )
    </insert>

    <select id="findByRecordId"
            parameterType="java.lang.Long"
            resultMap="WritingRecordAttachmentResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM writing_record_attachment
        WHERE record_id = #{recordId}
        ORDER BY sort_order ASC, id ASC
    </select>

    <delete id="deleteByRecordId"
            parameterType="java.lang.Long">
        DELETE FROM writing_record_attachment
        WHERE record_id = #{recordId}
    </delete>

    <update id="updateOcrText"
            parameterType="com.andrew.smartielts.writing.domain.pojo.WritingRecordAttachment">
        UPDATE writing_record_attachment
        SET ocr_text = #{ocrText}
        WHERE id = #{id}
    </update>



</mapper>
