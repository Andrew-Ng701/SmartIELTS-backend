<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.andrew.smartielts.writing.mapper.WritingRecordAttachmentMapper">

    <resultMap id="WritingRecordAttachmentMap" type="com.andrew.smartielts.writing.domain.pojo.WritingRecordAttachment">
        <id property="id" column="id"/>
        <result property="recordId" column="record_id"/>
        <result property="fileType" column="file_type"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileKey" column="file_key"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdTime" column="created_time"/>
        <result property="ocrText" column="ocr_text"/>
    </resultMap>

    <insert id="insert" parameterType="com.andrew.smartielts.writing.domain.pojo.WritingRecordAttachment"
            useGeneratedKeys="true" keyProperty="id">
        insert into writing_record_attachment (
            record_id,
            file_type,
            file_url,
            file_key,
            sort_order,
            created_time,
            ocr_text
        ) values (
                     #{recordId},
                     #{fileType},
                     #{fileUrl},
                     #{fileKey},
                     #{sortOrder},
                     #{createdTime},
                     #{ocrText}
                 )
    </insert>

    <select id="findByRecordId" resultMap="WritingRecordAttachmentMap">
        select
            id,
            record_id,
            file_type,
            file_url,
            file_key,
            sort_order,
            created_time,
            ocr_text
        from writing_record_attachment
        where record_id = #{recordId}
        order by sort_order asc, id asc
    </select>

    <select id="countByRecordIds" resultType="map">
        select
            record_id as recordId,
            count(1) as attachmentCount
        from writing_record_attachment
        where record_id in
        <foreach collection="recordIds" item="recordId" open="(" separator="," close=")">
            #{recordId}
        </foreach>
        group by record_id
    </select>

    <update id="updateOcrText" parameterType="com.andrew.smartielts.writing.domain.pojo.WritingRecordAttachment">
        update writing_record_attachment
        set ocr_text = #{ocrText}
        where id = #{id}
    </update>

    <delete id="deleteByRecordId">
        delete from writing_record_attachment
        where record_id = #{recordId}
    </delete>

</mapper>
