<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.andrew.smartielts.auth.mapper.AuthMapper">

    <insert id="save"
            parameterType="com.andrew.smartielts.auth.domain.pojo.User"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO sys_user (email, password, role)
        VALUES (#{email}, #{password}, #{role})
    </insert>

    <select id="findByEmail"
            resultType="com.andrew.smartielts.auth.domain.pojo.User">
        SELECT id, email, password, role
        FROM sys_user
        WHERE email = #{email}
        LIMIT 1
    </select>

    <select id="existsByEmail" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM sys_user
        WHERE email = #{email}
    </select>

</mapper>
